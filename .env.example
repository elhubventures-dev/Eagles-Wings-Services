# App
NEXT_PUBLIC_URL=https://e-wingss.com
NEXT_PUBLIC_SITE_NAME="Eagle Wings Services Ltd."

# Email delivery (Resend)
# Verify your domain in Resend, then use a from-address on that domain.
RESEND_API_KEY=re_xxxxxxxx
CONTACT_FROM_EMAIL="Eagle Wings Services <noreply@e-wingss.com>"

# Admin inbox for enquiry + newsletter notifications
CONTACT_TO_EMAIL=info@e-wingss.com

# Optional: also add newsletter subscribers to a Resend audience
RESEND_AUDIENCE_ID=

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
